{% extends 'base.html.twig' %}

{% block title %}Connexion - StorePHP{% endblock %}

{% block body %}
  <section class="auth">
    <div class="auth__card">
      <p class="kicker">Admin</p>
      <h1>Connexion</h1>

      {% if error %}
        <div class="notice notice--error">
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      <form method="post" class="form" autocomplete="off">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

        <label class="field">
          <span class="field__label">Email</span>
          <input class="input" type="email" name="_username" value="" autocomplete="off" required />
        </label>

        <label class="field">
          <span class="field__label">Mot de passe</span>
          <input class="input" type="password" name="_password" autocomplete="new-password" required />
        </label>

        <button class="btn btn--primary" type="submit">Se connecter</button>
      </form>
    </div>
  </section>
{% endblock %}
