<!doctype html>
{% set isRtl = app.request.locale starts with 'ar' %}
<html lang="{{ app.request.locale|default('fr') }}" dir="{{ isRtl ? 'rtl' : 'ltr' }}" class="{{ isRtl ? 'font-ar' : 'font-latin' }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="{{ isRtl ? 'متجر إلكتروني للمتجات عالية الجودة' : 'Boutique en ligne pour produits premium' }}" />
    
    <!-- Meta Pixel Code -->
    <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1299962548675283');
    fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1299962548675283&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->

    <title>{% block title %}StorePHP{% endblock %}</title>
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}" />
    <link rel="alternate" type="application/xml" title="Sitemap" href="{{ asset('sitemap.xml') }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300..900&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
    {% block stylesheets %}
      <link rel="stylesheet" href="{{ asset('styles/app.css') }}" />
    {% endblock %}
    {% block javascripts %}
      {{ importmap('app') }}
    {% endblock %}
  </head>
  <body class="bg-slate-50 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-lg border-b border-slate-200/50 shadow-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo -->
          <a href="{{ path('home') }}" class="flex items-center gap-2 group">
            <div class="h-9 w-9 rounded-xl bg-gradient-to-br from-cyan-500 via-emerald-500 to-amber-500 flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow duration-300">
              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
            </div>
            <span class="text-xl font-black tracking-tight text-slate-900 hidden sm:block">
              <span class="bg-gradient-to-r from-cyan-600 via-emerald-600 to-amber-600 bg-clip-text text-transparent">Store</span><span class="text-slate-900">PHP</span>
            </span>
          </a>

          <!-- Navigation -->
          <nav class="hidden md:flex items-center gap-1">
            <a href="{{ path('shop') }}" class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-xl transition-all duration-200">
              {{ isRtl ? 'المنتجات' : 'Produits' }}
            </a>
          </nav>

          <!-- Right Side -->
          <div class="flex items-center gap-2">
            <!-- Phone -->
            <a href="tel:+212661234567" class="hidden lg:flex items-center gap-2 px-3 py-2 text-sm font-semibold text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-xl transition-all duration-200">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span>+212 6 61 23 45 67</span>
            </a>

            <!-- Language Switcher -->
            <div class="h-6 w-px bg-slate-200 mx-1 hidden sm:block"></div>
            {% if isRtl %}
              <a href="{{ path('set_locale', { _locale: 'fr' }) }}" class="px-3 py-1.5 text-xs font-bold tracking-wider text-slate-500 hover:text-cyan-600 hover:bg-cyan-50 rounded-lg transition-all duration-200">
                FR
              </a>
            {% else %}
              <a href="{{ path('set_locale', { _locale: 'ar' }) }}" class="px-3 py-1.5 text-xs font-bold tracking-wider text-slate-500 hover:text-cyan-600 hover:bg-cyan-50 rounded-lg transition-all duration-200">
                AR
              </a>
            {% endif %}

            <!-- Admin -->
            {% if is_granted('ROLE_ADMIN') %}
              <a href="{{ path('admin') }}" class="p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-xl transition-all duration-200" title="Admin">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-white mt-auto">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand -->
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center gap-2 mb-4">
              <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-cyan-500 via-emerald-500 to-amber-500 flex items-center justify-center">
                <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
              </div>
              <span class="text-xl font-black">
                <span class="bg-gradient-to-r from-cyan-400 via-emerald-400 to-amber-400 bg-clip-text text-transparent">Store</span><span class="text-white">PHP</span>
              </span>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed max-w-md">
              {{ isRtl ? 'متجر إلكتروني رائد للمنتجات عالية الجودة. توصيل سريع لجميع المدن المغربية.' : 'Boutique en ligne leader pour produits premium. Expedition rapide dans tout le Maroc.' }}
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="font-bold text-sm tracking-wider text-slate-300 mb-4 uppercase">
              {{ isRtl ? 'روابط سريعة' : 'Liens rapides' }}
            </h4>
            <ul class="space-y-2">
              <li><a href="{{ path('shop') }}" class="text-slate-400 hover:text-white text-sm transition-colors duration-200">{{ isRtl ? 'المنتجات' : 'Produits' }}</a></li>
              <li><a href="#" class="text-slate-400 hover:text-white text-sm transition-colors duration-200">{{ isRtl ? 'من نحن' : 'A propos' }}</a></li>
              <li><a href="#" class="text-slate-400 hover:text-white text-sm transition-colors duration-200">{{ isRtl ? 'سياسة الخصوصية' : 'Politique de confidentialite' }}</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="font-bold text-sm tracking-wider text-slate-300 mb-4 uppercase">
              {{ isRtl ? 'اتصل بنا' : 'Contact' }}
            </h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-2 text-slate-400 text-sm">
                <svg class="h-4 w-4 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span>+212 6 61 23 45 67</span>
              </li>
              <li class="flex items-center gap-2 text-slate-400 text-sm">
                <svg class="h-4 w-4 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span>contact@storecod.org</span>
              </li>
              <li class="flex items-start gap-2 text-slate-400 text-sm">
                <svg class="h-4 w-4 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>{{ isRtl ? 'المغرب' : 'Maroc' }}</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-slate-800 mt-10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-slate-500 text-sm">
            &copy; {{ 'now'|date('Y') }} StorePHP. {{ isRtl ? 'جميع الحقوق محفوظة.' : 'Tous droits reserves.' }}
          </p>
          <div class="flex items-center gap-4">
            <!-- Social Icons -->
            <a href="#" class="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all duration-200" aria-label="Facebook">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="#" class="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all duration-200" aria-label="Instagram">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>