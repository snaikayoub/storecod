{% extends 'base.html.twig' %}

{% block title %}{{ isRtl ? 'المتجر' : 'Boutique' }} - StorePHP{% endblock %}

{% block body %}
  {% set isRtl = app.request.locale starts with 'ar' %}

  {% for message in app.flashes('success') %}
    <div class="mb-6 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-2xl border border-emerald-200 bg-emerald-50/90 px-6 py-4 text-sm font-semibold text-emerald-800 shadow-sm backdrop-blur">
        {{ message }}
      </div>
    </div>
  {% endfor %}

  <!-- Hero Section -->
  <section class="relative overflow-hidden border-b border-white/50 bg-[linear-gradient(140deg,rgba(15,23,42,0.98),rgba(30,41,59,0.96),rgba(15,118,110,0.88))] py-8 sm:py-10 lg:py-12">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%239C92AC\' fill-opacity=\'0.15\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
    </div>
    
    <div class="relative mx-auto grid max-w-6xl gap-6 px-4 sm:px-5 lg:grid-cols-[1.2fr_0.8fr] lg:items-center lg:px-6 {{ isRtl ? 'lg:text-right' : '' }}">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-white/8 px-3 py-1 text-[11px] font-black tracking-[0.2em] text-cyan-200 backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-cyan-300 shadow-[0_0_0_4px_rgba(103,232,249,0.15)]"></span>
          {{ isRtl ? 'متجر رقمي سريع' : 'BOUTIQUE NEXT-GEN' }}
        </div>
        <h1 class="mt-4 text-3xl font-black leading-tight tracking-tight text-white sm:text-4xl lg:text-5xl">
          {{ isRtl ? 'منتجات منتقاة' : 'Selection premium' }}
          <span class="block bg-gradient-to-r from-cyan-300 via-emerald-300 to-amber-300 bg-clip-text text-transparent">
            {{ isRtl ? 'بتجربة شراء أسرع' : 'avec une experience plus rapide' }}
          </span>
        </h1>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300 sm:text-base {{ isRtl ? 'lg:mr-0 lg:ml-auto' : '' }}">
          {{ isRtl ? 'واجهة مضغوطة وواضحة لعرض أفضل المنتجات مع دفع عند الاستلام وتوصيل سريع لجميع المدن المغربية.' : 'Une vitrine compacte et futuriste pour mettre en avant vos meilleurs produits avec paiement a la livraison et expedition rapide au Maroc.' }}
        </p>
        <div class="mt-5 flex flex-wrap items-center gap-2.5 {{ isRtl ? 'lg:justify-end' : '' }}">
          <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-3 py-1.5 text-xs font-semibold text-white backdrop-blur">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            {{ isRtl ? 'توصيل مجاني' : 'Livraison gratuite' }}
          </div>
          <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-3 py-1.5 text-xs font-semibold text-white backdrop-blur">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            {{ isRtl ? 'دفع عند الاستلام' : 'Paiement a la livraison' }}
          </div>
          <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-3 py-1.5 text-xs font-semibold text-white backdrop-blur">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            {{ isRtl ? 'ضمان الجودة' : 'Garantie qualite' }}
          </div>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-3 rounded-[28px] border border-white/10 bg-white/6 p-3 shadow-[0_20px_70px_rgba(15,23,42,0.35)] backdrop-blur">
        {% for p in products|slice(0, 3) %}
          <a href="{{ path('product_show', { slug: p.slug }) }}" class="group overflow-hidden rounded-[22px] border border-white/10 bg-white/6 transition-transform duration-300 hover:-translate-y-1">
            <img src="{{ p.primaryImageUrl|default(p.referenceImageUrl) }}" alt="{{ p.title }}" class="aspect-[4/5] h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </a>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section class="py-8 sm:py-10 lg:py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="mb-5 flex items-center justify-between">
        <div>
          <h2 class="text-xl font-black tracking-tight text-slate-900 sm:text-2xl">
            {{ isRtl ? 'منتجاتنا' : 'Nos Produits' }}
          </h2>
          <p class="mt-1 text-sm text-slate-500">
            {{ products|length }} {{ isRtl ? 'منتج متوفر' : 'produit(s) disponible(s)' }}
          </p>
        </div>
      </div>

      {% if products is empty %}
        <div class="text-center py-16">
          <div class="mx-auto h-24 w-24 rounded-full bg-slate-100 flex items-center justify-center mb-4">
            <svg class="h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <p class="text-slate-500 text-lg">{{ isRtl ? 'لا توجد منتجات حالياً' : 'Aucun produit pour le moment.' }}</p>
        </div>
      {% else %}
        <!-- Products Grid -->
        <div class="grid [grid-template-columns:repeat(auto-fit,minmax(248px,292px))] justify-center gap-4">
          {% for p in products %}
            <a href="{{ path('product_show', { slug: p.slug }) }}" class="group block min-w-0">
              <div class="overflow-hidden rounded-[26px] border border-white/70 bg-white/90 shadow-[0_16px_40px_rgba(148,163,184,0.16)] transition-all duration-300 hover:-translate-y-1 hover:border-cyan-200 hover:shadow-[0_22px_50px_rgba(34,211,238,0.16)]">
                <!-- Image -->
                <div class="relative aspect-square overflow-hidden bg-slate-100">
                  <img 
                    src="{{ p.primaryImageUrl|default(p.referenceImageUrl) }}" 
                    alt="{{ p.title }}"
                    class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                  <!-- Sale Badge -->
                  {% if p.priceBaseCents > 0 and p.priceBaseCents > p.priceSaleCents %}
                    {% set discount = ((p.priceBaseCents - p.priceSaleCents) / p.priceBaseCents * 100)|round %}
                    <div class="absolute left-3 top-3 rounded-full bg-red-500 px-2.5 py-1 text-[11px] font-bold text-white shadow-lg">
                      -{{ discount }}%
                    </div>
                  {% endif %}
                </div>

                <!-- Content -->
                <div class="p-4">
                  <h3 class="line-clamp-2 text-sm font-bold text-slate-900 transition-colors duration-200 group-hover:text-cyan-600 sm:text-base">
                    {{ p.title }}
                  </h3>
                  
                  {% set d = p.getDescriptionForLocale(app.request.locale) %}
                  {% if d %}
                    <p class="mt-2 line-clamp-2 text-xs leading-5 text-slate-500 sm:text-sm">
                      {{ d|striptags }}
                    </p>
                  {% endif %}

                  <div class="mt-3 flex items-center justify-between gap-2 border-t border-slate-100 pt-3">
                    <div class="flex items-baseline gap-2">
                      <span class="text-lg font-black text-slate-900 sm:text-xl">
                        {{ (p.priceSaleCents / 100)|number_format(0, '.', ' ') }}
                        <span class="text-sm font-bold text-slate-500">DH</span>
                      </span>
                      {% if p.priceBaseCents > 0 and p.priceBaseCents > p.priceSaleCents %}
                        <span class="text-xs sm:text-sm font-medium text-slate-400 line-through">
                          {{ (p.priceBaseCents / 100)|number_format(0, '.', ' ') }} DH
                        </span>
                      {% endif %}
                    </div>
                    <span class="inline-flex items-center gap-1 whitespace-nowrap rounded-full bg-cyan-50 px-2.5 py-1.5 text-[11px] font-bold text-cyan-700 transition-colors duration-200 group-hover:bg-cyan-600 group-hover:text-white sm:text-xs">
                      {{ isRtl ? 'اطلب' : 'Commander' }}
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </div>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </section>
{% endblock %}
