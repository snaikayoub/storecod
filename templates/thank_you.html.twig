{% extends 'base.html.twig' %}

{% set isRtl = app.request.locale starts with 'ar' %}
{% set firstItem = order.items|first %}
{% set orderValue = (order.totalCents / 100)|number_format(2, '.', '') %}
{% set productName = firstItem ? firstItem.titleSnapshot : 'Commande' %}
{% set productId = firstItem and firstItem.product ? firstItem.product.id : order.id %}

{% block title %}{{ isRtl ? 'شكرا لك' : 'Merci pour votre commande' }} - StorePHP{% endblock %}

{% block body %}
  <div class="mx-auto max-w-2xl px-4 py-12 text-center">
    <div class="mb-6">
      <div class="mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-emerald-100">
        <svg class="h-10 w-10 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-2xl font-black tracking-tight text-slate-900">
        {{ isRtl ? 'شكرا لك! تم تسجيل طلبك' : 'Merci ! Commande enregistree' }}
      </h1>

      <p class="mt-2 text-slate-600">
        {{ isRtl ? 'سنتواصل معك لتأكيد الطلب.' : 'Nous vous contacterons rapidement pour confirmer votre commande.' }}
      </p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white/70 p-6 text-left shadow-sm">
      <div class="flex items-center justify-between gap-4 border-b border-slate-100 pb-3">
        <span class="text-sm font-bold text-slate-500">{{ isRtl ? 'رقم الطلب' : 'Commande' }}</span>
        <span class="text-sm font-black text-slate-900">#{{ order.id }}</span>
      </div>
      <div class="flex items-center justify-between gap-4 py-3 border-b border-slate-100">
        <span class="text-sm font-bold text-slate-500">{{ isRtl ? 'المنتج' : 'Produit' }}</span>
        <span class="text-sm font-black text-slate-900">{{ firstItem ? firstItem.titleSnapshot : 'Produit' }}</span>
      </div>
      <div class="flex items-center justify-between gap-4 pt-3">
        <span class="text-sm font-bold text-slate-500">{{ isRtl ? 'المبلغ' : 'Montant' }}</span>
        <span class="text-base font-black text-emerald-700">{{ orderValue }} MAD</span>
      </div>
    </div>

    <a href="{{ path('shop') }}" class="mt-6 inline-block rounded-2xl bg-slate-900 px-6 py-3 text-sm font-bold text-white">
      {{ isRtl ? 'عودة للمتجر' : 'Retour a la boutique' }}
    </a>
  </div>

  <script>
    (function() {
      var trackKey = 'purchase_tracked_order_{{ order.id }}';
      if (window.sessionStorage && window.sessionStorage.getItem(trackKey) === '1') {
        return;
      }

      fbq('track', 'Purchase', {
        content_name: {{ productName|json_encode|raw }},
        content_ids: [{{ productId|json_encode|raw }}],
        content_type: 'product',
        num_items: {{ firstItem ? firstItem.quantity : 1 }},
        value: {{ orderValue }},
        currency: 'MAD'
      });

      if (window.sessionStorage) {
        window.sessionStorage.setItem(trackKey, '1');
      }
    })();
  </script>
{% endblock %}
