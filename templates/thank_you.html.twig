{% extends 'base.html.twig' %}

{% block title %}{{ isRtl ? 'شكرا لك' : 'Merci pour votre commande' }} - StorePHP{% endblock %}

{% block body %}
  {% set isRtl = app.request.locale starts with 'ar' %}
  
  <div class="mx-auto max-w-2xl px-4 py-12 text-center">
    <div class="mb-6">
      <div class="mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-emerald-100">
        <svg class="h-10 w-10 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      
      <h1 class="text-2xl font-black tracking-tight text-slate-900">
        {{ isRtl ? 'شكرا لك ! تم تسجيل طلبك' : 'Merci ! Commande enregistree' }}
      </h1>
      
      <p class="mt-2 text-slate-600">
        {{ isRtl ? 'سنتواصل معك لتأكيد الطلب.' : 'Nous vous contacterons rapidement pour confirmer votre commande.' }}
      </p>
    </div>
    
    <div class="rounded-2xl border border-slate-200 bg-white/70 p-6">
      <p class="text-sm font-medium text-slate-700">
        {{ isRtl ? 'سيصلك طلبك最快的.' : 'Votre commande sera livree rapidement.' }}
      </p>
      <p class="mt-2 text-xs text-slate-500">
        {{ isRtl ? 'للاستفسار: تواصل معنا' : 'Questions ? Contactez-nous.' }}
      </p>
    </div>
    
    <a href="{{ path('shop') }}" class="mt-6 inline-block rounded-2xl bg-slate-900 px-6 py-3 text-sm font-bold text-white">
      {{ isRtl ? 'عودة للمتجر' : 'Retour a la boutique' }}
    </a>
  </div>
  
  <script>
    fbq('track', 'Lead', {
      content_name: 'Commande COD',
      value: 199,
      currency: 'MAD'
    });
  </script>
{% endblock %}