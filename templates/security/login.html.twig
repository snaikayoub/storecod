{% extends 'base.html.twig' %}

{% block title %}Connexion - StorePHP{% endblock %}

{% block body %}
  <section class="auth px-4 sm:px-5 lg:px-6">
    <div class="auth__card border border-white/70 bg-white/82 shadow-[0_20px_60px_rgba(148,163,184,0.16)] backdrop-blur">
      <p class="kicker text-[11px] tracking-[0.2em]">Admin</p>
      <h1 class="text-3xl font-black tracking-tight text-slate-900">Connexion</h1>
      <p class="mt-2 text-sm text-slate-500">Acces securise au tableau de bord StorePHP.</p>

      {% if error %}
        <div class="notice notice--error">
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      <form method="post" class="form" autocomplete="off">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

        <label class="field">
          <span class="field__label">Email</span>
          <input class="input" type="email" name="_username" value="" autocomplete="off" required />
        </label>

        <label class="field">
          <span class="field__label">Mot de passe</span>
          <input class="input" type="password" name="_password" autocomplete="new-password" required />
        </label>

        <button class="btn btn--primary rounded-2xl bg-gradient-to-r from-cyan-600 via-sky-600 to-emerald-500 shadow-[0_14px_30px_rgba(14,165,233,0.18)]" type="submit">Se connecter</button>
      </form>
    </div>
  </section>
{% endblock %}
