{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Import Produit (HTML){% endblock %}

{% block main %}
  {% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
  {% endfor %}
  {% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
  {% endfor %}

  <div class="content-panel">
    <div class="content-panel-body">
      <p class="mb-3">Collez le HTML exporte de la page source. Idempotent: meme titre => meme slug => mise a jour.</p>

      <form method="post">
        <input type="hidden" name="_token" value="{{ csrf_token('import_html') }}" />

        <div class="form-check mb-3">
          <input class="form-check-input" type="checkbox" name="bulk" value="1" id="bulkImport" />
          <label class="form-check-label" for="bulkImport">Importer toutes les offres detectees</label>
          <small class="form-text text-muted">Si coche, le champ "Titre" devient un filtre (optionnel) et plusieurs produits seront importes.</small>
        </div>

        <div class="form-group">
          <label class="form-control-label">Titre (optionnel)</label>
          <input class="form-control" type="text" name="titleHint" placeholder="Ex: Jean Levi's" />
          <small class="form-text text-muted">Mode simple: aide a choisir un produit. Mode bulk: filtre (contient) sur le titre.</small>
        </div>

        <div class="form-group">
          <label class="form-control-label">HTML</label>
          <textarea class="form-control" name="html" rows="18" required></textarea>
        </div>

        <button class="btn btn-primary" type="submit">Importer</button>
      </form>
    </div>
  </div>
{% endblock %}
